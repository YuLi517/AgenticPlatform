# =============================================================================
# VerticalAgent Stage 1 —— 环境变量配置模板
# =============================================================================
# 用法:
#   cp .env.example .env
#   编辑 .env 填入你的真实 API Key
# =============================================================================

# ----- 全局配置 -----
HOST=0.0.0.0
PORT=8000
MAX_HISTORY=10
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=2048

# ----- 多 Provider 配置 -----
# 逗号分隔，第一个为 primary（默认）
LLM_PROVIDERS=deepseek,qwen

# ---------- DeepSeek ----------
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30
DEEPSEEK_FAILURE_THRESHOLD=5
DEEPSEEK_RECOVERY_TIME=60

# ---------- Qwen (DashScope) ----------
QWEN_API_KEY=sk-your-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT=30
QWEN_FAILURE_THRESHOLD=5
QWEN_RECOVERY_TIME=60

# ---------- Moonshot (可选) ----------
# MOONSHOT_API_KEY=sk-your-moonshot-key
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=moonshot-v1-8k
# MOONSHOT_TIMEOUT=30
# MOONSHOT_FAILURE_THRESHOLD=5
# MOONSHOT_RECOVERY_TIME=60

# ---------- OpenAI (可选) ----------
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT=30
# OPENAI_FAILURE_THRESHOLD=5
# OPENAI_RECOVERY_TIME=60

# =============================================================================
# Stage 2C —— Embedding 配置（用于 RAG 检索）
# =============================================================================
# 留空 = 禁用 RAG（/search 和 /chat/rag 不可用，但 chat 不受影响）
# OpenAI 兼容 /embeddings 端点的服务都可以填
# =============================================================================

# Embedding provider 名（OpenAI / ZHIPU / QWEN ...）
# 必须大写，对应下面的 {PROVIDER}_API_KEY / {PROVIDER}_BASE_URL / {PROVIDER}_EMBEDDING_MODEL
EMBEDDING_PROVIDER=

# ---------- OpenAI Embedding ----------
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSION=1536

# ---------- 智谱 Embedding (OpenAI 兼容) ----------
# ZHIPU_API_KEY=your-zhipu-key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_EMBEDDING_MODEL=embedding-3
# ZHIPU_EMBEDDING_DIMENSION=2048

# ---------- Qwen Embedding (DashScope 兼容模式) ----------
# QWEN_API_KEY=sk-your-qwen-key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_EMBEDDING_MODEL=text-embedding-v3
# QWEN_EMBEDDING_DIMENSION=1024

# Embedding 通用配置
EMBEDDING_TIMEOUT=30
# EMBEDDING_API_KEY=  # 通用 fallback key（如果上面的 provider 没匹配）
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSION=

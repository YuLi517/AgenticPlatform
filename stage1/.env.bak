# =============================================================================
# VerticalAgent Stage 0 —— 环境变量配置模板
# =============================================================================
# 使用方法:
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 填入你的真实 API Key
#   3. python main.py 启动
# =============================================================================

# LLM Provider 选择: deepseek / qwen / moonshot / openai
LLM_PROVIDER=MiniMax

# API Key（在对应平台注册账号获取）
# DeepSeek:   https://platform.deepseek.com
# Qwen:       https://dashscope.aliyun.com
# Moonshot:   https://platform.moonshot.cn
# OpenAI:     https://platform.openai.com
LLM_API_KEY=sk-cp-UVOUQilkZoSUc9KyDW5ZBKJssBxN6GmSJacPaTlHK-LxvlEpuzaZmAOsKUYP1MpQBSs5fkGpZaAWNnK8QyG5oLSAGlFJ5XZXNzDtsV78ZBsWRHe-9-UdYGw

# API Base URL（OpenAI 兼容）
LLM_BASE_URL=https://api.minimax.chat/v1

# 模型名称
LLM_MODEL=MiniMax-M2.7-highspeed

# 单次响应最大 Token 数
LLM_MAX_TOKENS=128000

# 请求超时（秒）
LLM_TIMEOUT=30

# 多轮对话保留消息数（10 = 5 轮）
MAX_HISTORY=10

# 失败重试次数（限流/超时/网络问题）
MAX_RETRIES=2

# 服务监听地址
HOST=0.0.0.0
PORT=8000
